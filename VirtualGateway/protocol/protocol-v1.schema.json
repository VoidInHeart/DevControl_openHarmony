{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devcontrol.local/schema/protocol-v1.json",
  "title": "DevControl Protocol 1.0",
  "type": "object",
  "$defs": {
    "baseDevice": {
      "type": "object",
      "required": [
        "id",
        "name",
        "roomId",
        "type",
        "online",
        "stateVersion",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 3,
          "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$"
        },
        "name": { "type": "string", "minLength": 1 },
        "roomId": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$"
        },
        "type": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$"
        },
        "online": { "type": "boolean" },
        "stateVersion": { "type": "integer", "minimum": 0 },
        "updatedAt": { "type": "string" }
      }
    },
    "lightDevice": {
      "allOf": [
        { "$ref": "#/$defs/baseDevice" },
        {
          "type": "object",
          "required": ["power", "brightness", "automation"],
          "properties": {
            "type": { "const": "light" },
            "power": { "type": "boolean" },
            "brightness": { "type": "integer", "minimum": 0, "maximum": 100 },
            "lastNonZeroBrightness": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "automation": {
              "type": "object",
              "required": [
                "enabled",
                "illuminanceThresholdLux",
                "noPresenceDelaySeconds"
              ],
              "properties": {
                "enabled": { "type": "boolean" },
                "illuminanceThresholdLux": {
                  "type": "integer",
                  "minimum": 10,
                  "maximum": 500
                },
                "noPresenceDelaySeconds": {
                  "type": "integer",
                  "minimum": 5,
                  "maximum": 600
                },
                "manualOverrideUntil": {
                  "type": ["integer", "null"]
                }
              }
            }
          }
        }
      ]
    },
    "environmentDevice": {
      "allOf": [
        { "$ref": "#/$defs/baseDevice" },
        {
          "type": "object",
          "required": [
            "temperatureCelsius",
            "humidityPercent",
            "illuminanceLux",
            "presence",
            "dataValid"
          ],
          "properties": {
            "type": { "const": "environment" },
            "temperatureCelsius": { "type": "number" },
            "humidityPercent": { "type": "number" },
            "illuminanceLux": { "type": "number", "minimum": 0 },
            "presence": { "type": "boolean" },
            "dataValid": { "type": "boolean" }
          }
        }
      ]
    },
    "airConditionerDevice": {
      "allOf": [
        { "$ref": "#/$defs/baseDevice" },
        {
          "type": "object",
          "required": [
            "brand",
            "power",
            "mode",
            "targetTemperatureCelsius",
            "fanSpeed",
            "running"
          ],
          "properties": {
            "type": { "const": "airConditioner" },
            "brand": {
              "enum": ["generic", "haierSim", "greeSim", "mideaSim"]
            },
            "power": { "type": "boolean" },
            "mode": { "enum": ["auto", "cool", "heat", "dry", "fan"] },
            "targetTemperatureCelsius": {
              "type": "integer",
              "minimum": 16,
              "maximum": 30
            },
            "fanSpeed": { "enum": ["auto", "low", "medium", "high"] },
            "running": { "type": "boolean" },
            "lastAdapterFrame": { "type": "string" }
          }
        }
      ]
    },
    "doorLockDevice": {
      "allOf": [
        { "$ref": "#/$defs/baseDevice" },
        {
          "type": "object",
          "required": [
            "locked",
            "jammed",
            "batteryPercent",
            "autoLockEnabled",
            "autoLockDelaySeconds"
          ],
          "properties": {
            "type": { "const": "doorLock" },
            "locked": { "type": "boolean" },
            "jammed": { "type": "boolean" },
            "batteryPercent": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "autoLockEnabled": { "type": "boolean" },
            "autoLockDelaySeconds": {
              "type": "integer",
              "minimum": 5,
              "maximum": 60
            },
            "autoLockAt": { "type": ["integer", "null"] }
          }
        }
      ]
    },
    "deviceCategory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "icon", "homeOnly"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$"
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 32 },
        "icon": { "type": "string", "minLength": 1, "maxLength": 8 },
        "homeOnly": { "type": "boolean" }
      }
    },
    "controlOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "label"],
      "properties": {
        "value": { "type": "string", "minLength": 1, "maxLength": 64 },
        "label": { "type": "string", "minLength": 1, "maxLength": 32 }
      }
    },
    "deviceControl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "label", "action"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$"
        },
        "kind": { "enum": ["button", "toggle", "slider", "enum"] },
        "label": { "type": "string", "minLength": 1, "maxLength": 32 },
        "action": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$"
        },
        "stateKey": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$"
        },
        "payloadKey": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$"
        },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" },
        "step": { "type": "number", "exclusiveMinimum": 0 },
        "unit": { "type": "string", "maxLength": 16 },
        "options": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": { "$ref": "#/$defs/controlOption" }
        },
        "primary": { "type": "boolean" },
        "requiresConfirmation": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "toggle" } },
            "required": ["kind"]
          },
          "then": { "required": ["stateKey", "payloadKey"] }
        },
        {
          "if": {
            "properties": { "kind": { "const": "slider" } },
            "required": ["kind"]
          },
          "then": {
            "required": [
              "stateKey",
              "payloadKey",
              "minimum",
              "maximum",
              "step"
            ]
          }
        },
        {
          "if": {
            "properties": { "kind": { "const": "enum" } },
            "required": ["kind"]
          },
          "then": {
            "required": ["stateKey", "payloadKey", "options"]
          }
        }
      ]
    },
    "genericDevice": {
      "allOf": [
        { "$ref": "#/$defs/baseDevice" },
        {
          "type": "object",
          "required": ["category", "state", "controls"],
          "properties": {
            "type": {
              "not": {
                "enum": [
                  "light",
                  "environment",
                  "airConditioner",
                  "doorLock"
                ]
              }
            },
            "category": { "$ref": "#/$defs/deviceCategory" },
            "state": {
              "type": "object",
              "maxProperties": 32,
              "propertyNames": {
                "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$"
              },
              "additionalProperties": {
                "oneOf": [
                  { "type": "string", "maxLength": 256 },
                  { "type": "number" },
                  { "type": "boolean" },
                  { "type": "null" }
                ]
              }
            },
            "controls": {
              "type": "array",
              "minItems": 1,
              "maxItems": 32,
              "items": { "$ref": "#/$defs/deviceControl" }
            }
          }
        }
      ]
    },
    "device": {
      "oneOf": [
        { "$ref": "#/$defs/lightDevice" },
        { "$ref": "#/$defs/environmentDevice" },
        { "$ref": "#/$defs/airConditionerDevice" },
        { "$ref": "#/$defs/doorLockDevice" },
        { "$ref": "#/$defs/genericDevice" }
      ]
    },
    "secureCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocolVersion",
        "messageId",
        "deviceId",
        "timestamp",
        "type",
        "action",
        "expectedStateVersion",
        "nonce",
        "ciphertext",
        "authTag"
      ],
      "properties": {
        "protocolVersion": { "const": "1.0" },
        "messageId": { "type": "string", "minLength": 16 },
        "deviceId": { "type": "string", "minLength": 3 },
        "timestamp": { "type": "integer" },
        "type": { "const": "command.request" },
        "action": { "type": "string", "minLength": 1 },
        "expectedStateVersion": { "type": ["integer", "null"] },
        "nonce": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{16}$"
        },
        "ciphertext": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "authTag": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{22}$"
        }
      }
    },
    "pairRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "pairingCode", "clientId"],
      "properties": {
        "protocolVersion": { "const": "1.0" },
        "pairingCode": { "type": "string", "pattern": "^\\d{6}$" },
        "clientId": { "type": "string", "minLength": 8, "maxLength": 128 }
      }
    },
    "pairResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocolVersion",
        "clientId",
        "credential",
        "dataKey",
        "issuedAt",
        "expiresAt"
      ],
      "properties": {
        "protocolVersion": { "const": "1.0" },
        "clientId": { "type": "string" },
        "credential": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$"
        },
        "dataKey": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$"
        },
        "issuedAt": { "type": "integer" },
        "expiresAt": { "type": "integer" }
      }
    },
    "commandResult": {
      "type": "object",
      "required": [
        "protocolVersion",
        "type",
        "timestamp",
        "messageId",
        "success",
        "error"
      ],
      "properties": {
        "protocolVersion": { "const": "1.0" },
        "type": { "const": "command.result" },
        "timestamp": { "type": "integer" },
        "messageId": { "type": "string" },
        "deviceId": { "type": "string" },
        "action": { "type": "string" },
        "success": { "type": "boolean" },
        "stateVersion": { "type": "integer", "minimum": 0 },
        "error": {
          "type": ["object", "null"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "retryAfterSeconds": { "type": ["integer", "null"] }
          }
        },
        "details": {
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "required": ["deviceId", "success", "errorCode"],
            "properties": {
              "deviceId": { "type": "string" },
              "success": { "type": "boolean" },
              "errorCode": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "stateChanged": {
      "type": "object",
      "required": [
        "protocolVersion",
        "type",
        "timestamp",
        "deviceId",
        "stateVersion",
        "device"
      ],
      "properties": {
        "protocolVersion": { "const": "1.0" },
        "type": { "const": "state.changed" },
        "timestamp": { "type": "integer" },
        "deviceId": { "type": "string" },
        "stateVersion": { "type": "integer", "minimum": 0 },
        "device": { "$ref": "#/$defs/device" }
      }
    },
    "heartbeat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "type", "timestamp"],
      "properties": {
        "protocolVersion": { "const": "1.0" },
        "type": { "const": "heartbeat" },
        "timestamp": { "type": "integer" }
      }
    },
    "alertRaised": {
      "type": "object",
      "required": [
        "protocolVersion",
        "type",
        "timestamp",
        "deviceId",
        "severity",
        "code",
        "description"
      ],
      "properties": {
        "protocolVersion": { "const": "1.0" },
        "type": { "const": "alert.raised" },
        "timestamp": { "type": "integer" },
        "deviceId": { "type": "string" },
        "severity": { "enum": ["info", "warning", "critical"] },
        "code": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "deviceSnapshotResponse": {
      "type": "object",
      "required": ["protocolVersion", "serverTime", "devices"],
      "properties": {
        "protocolVersion": { "const": "1.0" },
        "serverTime": { "type": "integer" },
        "devices": {
          "type": "array",
          "items": { "$ref": "#/$defs/device" }
        }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/device" },
    { "$ref": "#/$defs/secureCommand" },
    { "$ref": "#/$defs/pairRequest" },
    { "$ref": "#/$defs/pairResponse" },
    { "$ref": "#/$defs/commandResult" },
    { "$ref": "#/$defs/stateChanged" },
    { "$ref": "#/$defs/heartbeat" },
    { "$ref": "#/$defs/alertRaised" },
    { "$ref": "#/$defs/deviceSnapshotResponse" }
  ]
}
